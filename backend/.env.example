# Backend environment variables
# Copy this file to .env and fill in your values

# Database (local dev uses SQLite by default; production uses Supabase PostgreSQL)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Pinme LLM API (required for AI analysis features)
# Get your key from https://pinme.cloud
PINME_API_KEY=your_pinme_api_key_here
PINME_BASE_URL=https://pinme.cloud
PINME_PROJECT_NAME=lingjing-e0c1

# CORS allowed origins (comma-separated, production frontend URL)
# CORS_ALLOW_ORIGINS=https://your-app.vercel.app,https://your-app.pages.dev
